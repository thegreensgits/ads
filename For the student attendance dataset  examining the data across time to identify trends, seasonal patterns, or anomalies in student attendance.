# ================================
# Step 2: Import Libraries
# ================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# ================================
# Step 3: Upload Dataset
# ================================
from google.colab import files
uploaded = files.upload()

# ================================
# Step 4: Load Dataset
# ================================
df = pd.read_csv("Daily_Attendance.csv")  

# Clean column names
df.columns = df.columns.str.strip().str.lower()

# Replace '?' with NaN
df.replace('?', np.nan, inplace=True)

# Convert numeric columns
for col in df.columns:
    if col != 'date':
        df[col] = pd.to_numeric(df[col], errors='coerce')

# Drop missing values
df.dropna(inplace=True)

print("Dataset Loaded Successfully\n")
print(df.head())

# ================================
# Step 5: Convert Date
# ================================
df['date'] = pd.to_datetime(df['date'], errors='coerce')
df.dropna(inplace=True)

# Set index
df.set_index('date', inplace=True)

# ================================
# Step 6: Plot Attendance (Present)
# ================================
plt.figure()
plt.plot(df['present'])
plt.title("Student Attendance Over Time")
plt.xlabel("Date")
plt.ylabel("Present Students")
plt.show()

# ================================
# Step 7: Rolling Mean (Trend)
# ================================
df['rolling_mean'] = df['present'].rolling(window=7).mean()

plt.figure()
plt.plot(df['present'], label='Original')
plt.plot(df['rolling_mean'], label='Trend')
plt.legend()
plt.title("Trend Analysis")
plt.show()

# ================================
# Step 8: Anomaly Detection
# ================================
mean = df['present'].mean()
std = df['present'].std()

threshold = mean - 2 * std

anomalies = df[df['present'] < threshold]

print("\nAnomalies Detected:\n", anomalies)
