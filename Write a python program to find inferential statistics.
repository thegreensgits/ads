# ================================
# Step 2: Import Libraries
# ================================
import pandas as pd
import numpy as np
from scipy import stats

# ================================
# Step 3: Upload Dataset
# ================================
from google.colab import files
uploaded = files.upload()

# ================================
# Step 4: Load Dataset (Handle Errors)
# ================================
df = pd.read_csv("placement.csv")

# Clean column names
df.columns = df.columns.str.strip().str.lower()

# Replace '?' with NaN
df.replace('?', np.nan, inplace=True)

# Convert to numeric if needed
for col in df.columns:
    df[col] = pd.to_numeric(df[col], errors='coerce')

# Drop missing values
df.dropna(inplace=True)

print("Dataset Loaded Successfully\n")
print(df.head())

# ================================
# Step 5: Inferential Statistics (t-test)
# ================================

# Split data into two groups
placed = df[df['placed'] == 1]['cgpa']
not_placed = df[df['placed'] == 0]['cgpa']

# Perform Independent t-test
t_stat, p_value = stats.ttest_ind(placed, not_placed)

print("\n===== T-TEST RESULT =====")
print("T-Statistic:", t_stat)
print("P-Value:", p_value)

# ================================
# Step 6: Conclusion
# ================================
alpha = 0.05

if p_value < alpha:
    print("\nConclusion: Significant difference (Reject Null Hypothesis)")
else:
    print("\nConclusion: No significant difference (Fail to Reject Null Hypothesis)")
