print("\n--- Step 2: Data Collection ---")
print("Dataset shape:", df.shape)

# ================================
# STEP 6: Data Understanding
# ================================
print("\n--- Step 3: Data Understanding ---")
print(df.head())
print(df.info())

# ================================
# STEP 7: Data Cleaning
