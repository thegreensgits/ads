uploaded = files.upload()

# ================================
# STEP 3: Load Dataset
# ================================
df = pd.read_csv("diabetes.csv")

# ================================
# STEP 4: Problem Understanding
# ================================
print("\n--- Step 1: Problem Understanding ---")
print("Goal: Predict whether a person has diabetes or not")

# ================================
# STEP 5: Data Collection
