# ================================
# Step 2: Import Libraries
# ================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
from statsmodels.tsa.ar_model import AutoReg

# ================================
# Step 3: Create Dataset (IMPORTANT)
# ================================
data = {
    "month": [
        "1901-01","1901-02","1901-03","1901-04","1901-05","1901-06",
        "1901-07","1901-08","1901-09","1901-10","1901-11","1901-12",
        "1902-01","1902-02","1902-03","1902-04","1902-05","1902-06",
        "1902-07","1902-08","1902-09","1902-10","1902-11","1902-12",
        "1903-01","1903-02","1903-03","1903-04","1903-05","1903-06",
        "1903-07","1903-08","1903-09","1903-10","1903-11","1903-12"
    ],
    "sales": [
        266.0,145.9,183.1,119.3,180.3,168.5,
        231.8,224.5,192.8,122.9,336.5,185.9,
        194.3,149.5,210.1,273.3,191.4,287.0,
        226.0,303.6,289.9,421.6,264.5,342.3,
        339.7,440.4,315.9,439.3,401.3,437.4,
        575.5,407.6,682.0,475.3,581.3,646.9
    ]
}

df = pd.DataFrame(data)

print("Dataset Created Successfully ✅")
print(df.head())

# ================================
# Step 4: Convert to Time Series
# ================================
df['month'] = pd.to_datetime(df['month'], format='%Y-%m')
df.set_index('month', inplace=True)

# ================================
# Step 5: Plot Original Data
# ================================
plt.figure()
plt.plot(df['sales'])
plt.title("Shampoo Sales Over Time")
plt.show()

# ================================
# Step 6: Train-Test Split
# ================================
train = df['sales'][:-5]
test = df['sales'][-5:]

# ================================
# Step 7: Autoregression Model
# ================================
model = AutoReg(train, lags=3)
model_fit = model.fit()

# ================================
# Step 8: Predictions
# ================================
predictions = model_fit.predict(start=len(train), end=len(train)+len(test)-1)

# ================================
# Step 9: Plot Results
# ================================
plt.figure()
plt.plot(test.values, label='Actual')
plt.plot(predictions.values, label='Predicted')
plt.legend()
plt.title("Actual vs Predicted")
plt.show()

# ================================
# Step 10: Output
# ================================
print("\nPredictions:\n", predictions)
