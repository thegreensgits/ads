# ================================
# STEP 1: Import Libraries
# ================================
import pandas as pd
import numpy as np
from scipy.stats import zscore

# ================================
# STEP 2: Upload Dataset
# ================================
from google.colab import files
uploaded = files.upload()

# ================================
# STEP 3: Load Dataset
# ================================
df = pd.read_csv("olympics.csv", header=1)

# Rename first column
df.rename(columns={df.columns[0]: "Country"}, inplace=True)

# ================================
# STEP 4: Convert to Numeric
# ================================
df = df.apply(pd.to_numeric, errors='ignore')

# Extract numeric data
numeric_df = df.select_dtypes(include=[np.number])

# ================================
# STEP 5: Count BEFORE Outlier Removal
# ================================
print("Data count BEFORE outlier removal:", len(numeric_df))

# ================================
# STEP 6: Apply Z-Score Method
# ================================
z_scores = np.abs(zscore(numeric_df))

# Keep rows where ALL values are < 3
filtered_df = numeric_df[(z_scores < 3).all(axis=1)]

# ================================
# STEP 7: Count AFTER Outlier Removal
# ================================
print("Data count AFTER outlier removal:", len(filtered_df))

# ================================
# STEP 8: Show Difference
# ================================
removed = len(numeric_df) - len(filtered_df)
print("Number of outliers removed:", removed)
